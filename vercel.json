{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/api/$1"
    },
    {
      "source": "/(auth.html|admin.html|super-admin.html|styles.css|auth.css)",
      "destination": "/frontend/$1"
    },
    {
      "source": "/src/(.*)",
      "destination": "/frontend/src/$1"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}