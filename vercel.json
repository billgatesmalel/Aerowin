{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/auth",
      "destination": "/frontend/auth.html"
    },
    {
      "source": "/admin",
      "destination": "/frontend/admin.html"
    },
    {
      "source": "/super-admin",
      "destination": "/frontend/super-admin.html"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    }
  ]
}